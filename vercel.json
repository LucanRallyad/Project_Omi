{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/cron/sync-goodreads.ts": {
      "includeFiles": "{lib/**,src/types.ts,src/lib/**,src/data/**}"
    },
    "api/goodreads.ts": {
      "includeFiles": "lib/**"
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-goodreads",
      "schedule": "0 8 * * 0"
    }
  ]
}
