# Supabase project credentials (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: a lightweight passcode gate before the app loads.
# Leave blank to disable. If set, Romi enters this once to unlock.
VITE_APP_PASSCODE=

# Optional: Google Books API key (Google Cloud Console → APIs → Books API).
# Works without a key, but a key raises the daily request quota for covers
# and recommendation searches. Restrict the key to the Books API + your domain.
VITE_GOOGLE_BOOKS_API_KEY=

# Hardcover GraphQL API token (hardcover.app → Account → API).
# Server-side only — never prefix with VITE_. Used by /api/hardcover proxy.
# Required for Goodreads-quality covers and expanded recommendation search.
HARDCOVER_API_TOKEN=

# Romi's Goodreads user id (from review/list URL). Used by weekly RSS sync.
GOODREADS_USER_ID=71171257

# Protects /api/cron/sync-goodreads. Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
