{
  "name": "books-for-romi",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A cozy, personalized book recommendation web app made for Romi.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "parse-library": "tsx scripts/parseLibrary.ts",
    "fetch-covers": "tsx scripts/fetchLibraryCovers.ts",
    "fetch-descriptions": "tsx scripts/fetchLibraryDescriptions.ts",
    "fetch-library-meta": "tsx scripts/fetchLibraryCovers.ts && tsx scripts/fetchLibraryDescriptions.ts",
    "seed-library": "tsx scripts/parseLibrary.ts && tsx scripts/seedLibrary.ts",
    "sync-goodreads": "tsx scripts/syncGoodreads.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "d3-force": "^3.0.0",
    "framer-motion": "^11.11.7",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
